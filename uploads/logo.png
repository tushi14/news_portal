<p data-start="2175" data-end="2214">This creates one box for one news item.</p>
<p data-start="2216" data-end="2227">Inline CSS:</p>
<ul data-start="2228" data-end="2326">
<li data-section-id="trbv1e" data-start="2228" data-end="2253">
<p data-start="2230" data-end="2253"><code data-start="2230" data-end="2238">border</code> = outside line</p>
</li>
<li data-section-id="1cr51jw" data-start="2254" data-end="2280">
<p data-start="2256" data-end="2280"><code data-start="2256" data-end="2265">padding</code> = space inside</p>
</li>
<li data-section-id="rx5vto" data-start="2281" data-end="2326">
<p data-start="2283" data-end="2326"><code data-start="2283" data-end="2298">margin-bottom</code> = space after each news box</p>
</li>
