n><span class="ͼg">=</span><span class="ͼk">"uploads/</span><span class="ͼf">&lt;?php</span><span> </span><span class="ͼg">echo</span><span> </span><span class="ͼm">$row</span><span>[</span><span class="ͼk">'image'</span><span>]; </span><span class="ͼf">?&gt;</span><span class="ͼk">"</span><span> </span><span class="ͼn">width</span><span class="ͼg">=</span><span class="ͼk">"250"</span><span class="ͼo">&gt;</span><br><span>            </span><span class="ͼf">&lt;?php</span><span> } </span><span class="ͼf">?&gt;</span><br><br><span>            </span><span class="ͼo">&lt;p&gt;</span><span class="ͼf">&lt;?php</span><span> </span><span class="ͼg">echo</span><span> </span><span class="ͼm">substr</span><span>(</span><span class="ͼm">$row</span><span>[</span><span class="ͼk">'content'</span><span>], </span><span class="ͼj">0</span><span>, </span><span class="ͼj">100</span><span>); </span><span class="ͼf">?&gt;</span><span>...</span><span class="ͼo">&lt;/p&gt;</span><br><br><span>            </span><span class="ͼo">&lt;a</span><span> </span><span class="ͼn">href</span><span class="ͼg">=</span><span class="ͼk">"news_details.php?id=</span><span class="ͼf">&lt;?php</span><span> </span><span class="ͼg">echo</span><span> </span><span class="ͼm">$row</span><span>[</span><span class="ͼk">'id'</span><span>]; </span><span class="ͼf">?&gt;</span><span class="ͼk">"</span><span class="ͼo">&gt;</span><span>Read More</span><span class="ͼo">&lt;/a&gt;</span><br><span>        </span><span class="ͼo">&lt;/div&gt;</span><br><span class="ͼf">&lt;?php</span><br><span>    }</span><br><br><span>} </span><span class="ͼg">else</span><span> {</span><br><span class="ͼf">?&gt;</span><br><span>    </span><span class="ͼo">&lt;p&gt;</span><span>No news found</span><span class="ͼo">&lt;/p&gt;</span><br><span class="ͼf">&lt;?php</span><br><span>}</span><br><span class="ͼf">?&gt;</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="930" data-end="933">
<h2 data-section-id="a1jsjm" data-start="935" data-end="968">🔹 Logic flow (very important)</h2>
<pre class="overflow-visible! px-0!" data-start="970" data-end="1070"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>Check → any rows exist?</span><br><span>   ↓</span><br><span>YES → run while loop → show news</span><br><span>NO  → show "No news found"</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="1072" data-end="1075">
<h2 data-section-id="xxw0g1" data-start="1077" data-end="1110">🔹 Why not put it inside loop?</h2>
<p data-start="1112" data-end="1120">❌ Wrong:</p>
<pre class="overflow-visible! px-0!" data-start="1122" data-end="1167"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-430d4e28.svg#e45ab3" fill="currentColor"></use></svg>PHP</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>while(...) {</span><br><span>    if(...) { ... }</span><br><span>}</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1169" data-end="1177">Because:</p>
<ul data-start="1178" data-end="1255">
<li data-section-id="1n5q2wp" data-start="1178" data-end="1218">
<p data-start="1180" data-end="1218">If there are no rows → loop never runs</p>
</li>
<li data-section-id="1w3flfe" data-start="1219" data-end="1255">
<p data-start="1221" data-end="1255">So “No news found” will NEVER show</p>
</li>
</ul>
<hr data-start="1257" data-end="1260">
<h2 data-section-id="h53885" data-start="1262" data-end="1304">🔹 Common mistake (you almost did this)</h2>
<p data-start="1306" data-end="1363">You wrote <code data-start="1316" data-end="1325">if-else</code> separately without wrapping the loop.</p>
<p data-start="1365" data-end="1390">👉 That breaks the logic.</p>
<hr data-start="1392" data-end="1395">
<h2 data-section-id="hvod98" data-start="1397" data-end="1418">🔹 Think like this</h2>
<pre class="overflow-visible! px-0!" data-start="1420" data-end="1490"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>IF data exists</span><br><span>    LOOP through data</span><br><span>ELSE</span><br><span>    show message</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="1492" data-end="1495">
<h2 data-section-id="b0yae6" data-start="1497" data-end="1514">🔥 Quick check</h2>
<p data-start="1516" data-end="1557">If database is empty, what will show now?</p>
<p data-start="1559" data-end="1569">👉 Answer:</p>
<ul data-start="1570" data-end="1604">
<li data-section-id="1ahkeze" data-start="1570" data-end="1582">
<p data-start="1572" data-end="1582">News list?</p>
</li>
<li data-section-id="1o6iiz6" data-start="1583" data-end="1604">
<p data-start="1585" data-end="1604">OR "No news found"?</p>
</li>
</ul>
