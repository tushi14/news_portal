<h2 data-section-id="am2tzt" data-start="675" data-end="700">🔹 Step 4: Add columns</h2>
<p data-start="702" data-end="717">Fill like this:</p>
<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="719" data-end="1042" class="w-fit min-w-(--thread-content-width)"><thead data-start="719" data-end="766"><tr data-start="719" data-end="766"><th data-start="719" data-end="733" data-col-size="sm" class="">Name</th><th data-start="733" data-end="745" data-col-size="sm" class="">Type</th><th data-start="745" data-end="766" data-col-size="sm" class="">Extra</th></tr></thead><tbody data-start="813" data-end="1042"><tr data-start="813" data-end="858"><td data-start="813" data-end="827" data-col-size="sm">id</td><td data-start="827" data-end="838" data-col-size="sm">INT</td><td data-start="838" data-end="858" data-col-size="sm">AUTO_INCREMENT</td></tr><tr data-start="859" data-end="904"><td data-start="859" data-end="873" data-col-size="sm">headline</td><td data-start="873" data-end="884" data-col-size="sm">VARCHAR</td><td data-start="884" data-end="904" data-col-size="sm"></td></tr><tr data-start="905" data-end="950"><td data-start="905" data-end="919" data-col-size="sm">image</td><td data-start="919" data-end="930" data-col-size="sm">VARCHAR</td><td data-start="930" data-end="950" data-col-size="sm"></td></tr><tr data-start="951" data-end="996"><td data-start="951" data-end="965" data-col-size="sm">content</td><td data-start="965" data-end="976" data-col-size="sm">TEXT</td><td data-start="976" data-end="996" data-col-size="sm"></td></tr><tr data-start="997" data-end="1042"><td data-start="997" data-end="1011" data-col-size="sm">created_at</td><td data-start="1011" data-end="1022" data-col-size="sm">TIMESTAMP</td><td data-start="1022" data-end="1042" data-col-size="sm"></td></tr></tbody></table><div class="sticky h-0 select-none end-(--thread-content-margin) self-end"><div class="absolute end-0 flex items-end"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></button></span></div></div></div></div>
<p data-start="1044" data-end="1057">👉 Important:</p>
<ul data-start="1058" data-end="1120">
<li data-section-id="z5w76v" data-start="1058" data-end="1085">
<p data-start="1060" data-end="1085">Tick <strong data-start="1065" data-end="1076">PRIMARY</strong> for <code data-start="1081" data-end="1085">id</code></p>
</li>
<li data-section-id="1fw84lb" data-start="1086" data-end="1120">
<p data-start="1088" data-end="1120">Set length for VARCHAR = <strong data-start="1113" data-end="1120">255</strong></p>
</li>
</ul>
<p data-start="1122" data-end="1141">Then click <strong data-start="1133" data-end="1141">Save</strong></p>
