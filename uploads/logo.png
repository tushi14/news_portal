<h2 data-section-id="3gxvqa" data-start="1016" data-end="1060">🔹 Step 3: Add PHP logic (VERY IMPORTANT)</h2>
<p data-start="1062" data-end="1086">Put this <strong data-start="1071" data-end="1085">above HTML</strong>:</p>
<pre class="overflow-visible! px-0!" data-start="1088" data-end="1609"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-430d4e28.svg#e45ab3" fill="currentColor"></use></svg>PHP</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span class="ͼf">&lt;?php</span><br><span class="ͼg">include</span><span> </span><span class="ͼk">"../db.php"</span><span>;</span><br><br><span class="ͼg">if</span><span> (</span><span class="ͼm">isset</span><span>(</span><span class="ͼm">$_POST</span><span>[</span><span class="ͼk">'submit'</span><span>])) {</span><br><br><span>    </span><span class="ͼm">$headline</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">$_POST</span><span>[</span><span class="ͼk">'headline'</span><span>];</span><br><span>    </span><span class="ͼm">$content</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">$_POST</span><span>[</span><span class="ͼk">'content'</span><span>];</span><br><br><span>    </span><span class="ͼe">// image upload</span><br><span>    </span><span class="ͼm">$image</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">$_FILES</span><span>[</span><span class="ͼk">'image'</span><span>][</span><span class="ͼk">'name'</span><span>];</span><br><span>    </span><span class="ͼm">$tmp_name</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">$_FILES</span><span>[</span><span class="ͼk">'image'</span><span>][</span><span class="ͼk">'tmp_name'</span><span>];</span><br><br><span>    </span><span class="ͼm">move_uploaded_file</span><span>(</span><span class="ͼm">$tmp_name</span><span>, </span><span class="ͼk">"../uploads/"</span><span> </span><span class="ͼg">.</span><span> </span><span class="ͼm">$image</span><span>);</span><br><br><span>    </span><span class="ͼe">// insert query</span><br><span>    </span><span class="ͼm">$query</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼk">"INSERT INTO news (headline, image, content) </span><br><span class="ͼk">              VALUES ('</span><span class="ͼm">$headline</span><span class="ͼk">', '</span><span class="ͼm">$image</span><span class="ͼk">', '</span><span class="ͼm">$content</span><span class="ͼk">')"</span><span>;</span><br><br><span>    </span><span class="ͼm">mysqli_query</span><span>(</span><span class="ͼm">$conn</span><span>, </span><span class="ͼm">$query</span><span>);</span><br><br><span>    </span><span class="ͼg">echo</span><span> </span><span class="ͼk">"News added successfully"</span><span>;</span><br><span>}</span><br><span class="ͼf">?&gt;</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
