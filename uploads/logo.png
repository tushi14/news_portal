<h2 data-section-id="16nut9a" data-start="590" data-end="627">🔹 Key difference (very important)</h2>
<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="629" data-end="975" class="w-fit min-w-(--thread-content-width)"><thead data-start="629" data-end="699"><tr data-start="629" data-end="699"><th data-start="629" data-end="650" data-col-size="sm" class="">Thing</th><th data-start="650" data-end="664" data-col-size="sm" class="">Type</th><th data-start="664" data-end="699" data-col-size="sm" class="">Purpose</th></tr></thead><tbody data-start="769" data-end="975"><tr data-start="769" data-end="837"><td data-start="769" data-end="789" data-col-size="sm"><code data-start="771" data-end="784">news_portal</code></td><td data-start="789" data-end="803" data-col-size="sm">Database</td><td data-start="803" data-end="837" data-col-size="sm">Stores data (MySQL)</td></tr><tr data-start="838" data-end="906"><td data-start="838" data-end="858" data-col-size="sm"><code data-start="840" data-end="846">news</code></td><td data-start="858" data-end="872" data-col-size="sm">Table</td><td data-start="872" data-end="906" data-col-size="sm">Stores news records</td></tr><tr data-start="907" data-end="975"><td data-start="907" data-end="927" data-col-size="sm"><code data-start="909" data-end="927">news_details.php</code></td><td data-start="927" data-end="941" data-col-size="sm">PHP file</td><td data-start="941" data-end="975" data-col-size="sm">Displays one news item</td></tr></tbody></table><div class="sticky h-0 select-none end-(--thread-content-margin) self-end"><div class="absolute end-0 flex items-end"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></button></span></div></div></div></div>
